NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://moreshub:moreshub_dev@localhost:5432/moreshub
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Payment provider mode: mock | sandbox | production
PAYMENT_MODE=mock
# In production, refuses to start unless this is set:
BI_PJP_LICENSE_NO=

# QRIS (mock values; real values come from acquiring bank)
QRIS_MERCHANT_ID=ID1024000000000
QRIS_MERCHANT_NAME=MORESHUB DEMO
QRIS_MERCHANT_CITY=JAKARTA

# AML thresholds (IDR)
LTKT_THRESHOLD_IDR=500000000
DAILY_TXN_LIMIT_BASIC=2000000
DAILY_TXN_LIMIT_VERIFIED=20000000
DAILY_TXN_LIMIT_ENHANCED=200000000
